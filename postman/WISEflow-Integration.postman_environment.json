{
  "id": "wiseflow-integration-env",
  "name": "WISEflow Integration — Environment",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "baseUrl",
      "value": "https://your-institution.wiseflow.net",
      "type": "default",
      "enabled": true,
      "description": "WISEflow base URL — no trailing slash"
    },
    {
      "key": "clientId",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "OAuth2 client id (from WISEflow admin)"
    },
    {
      "key": "clientSecret",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "OAuth2 client secret (from WISEflow admin)"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by the Pre-request Script — do not set manually"
    },
    {
      "key": "tokenExpiry",
      "value": "0",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated — token expiry timestamp (ms)"
    },
    {
      "key": "userId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 01 Step 1 (or set manually)"
    },
    {
      "key": "roleId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 01 Step 3"
    },
    {
      "key": "userDataTypeId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 01 Step 6"
    },
    {
      "key": "flowTypeId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 02 Step 1"
    },
    {
      "key": "flowPurposeId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 02 Step 2"
    },
    {
      "key": "flowId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 02 Step 3, or set an existing flow id"
    },
    {
      "key": "participantUserId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "userId to enrol as a participant — set before running Package 03"
    },
    {
      "key": "assessorUserId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "userId to add as assessor — set before running Package 03"
    },
    {
      "key": "participantId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 03 Step 1"
    },
    {
      "key": "assessorId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 03 Step 3"
    },
    {
      "key": "assessorGroupId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Package 03 Step 5"
    },
    {
      "key": "sisEndpoint",
      "value": "http://localhost:8080/api/v1/grades",
      "type": "default",
      "enabled": true,
      "description": "Package 04: SIS/LMS grade ingestion endpoint"
    },
    {
      "key": "sisApiKey",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Package 04: SIS bearer token (optional)"
    },
    {
      "key": "lastMarks",
      "value": "{}",
      "type": "default",
      "enabled": true,
      "description": "Package 04: auto-populated after Step 2"
    },
    {
      "key": "transformedGrade",
      "value": "{}",
      "type": "default",
      "enabled": true,
      "description": "Package 04: auto-populated after Step 3 transform"
    }
  ]
}
