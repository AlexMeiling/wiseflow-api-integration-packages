# WISEflow Integration Packages — environment variables
# Copy this file to .env in the package directory you want to run, then fill in your values.
# NEVER commit .env files containing real credentials.

# WISEflow API base URL (no trailing slash)
WISEFLOW_BASE_URL=https://europe-api.wiseflow.net/v1

# OAuth2 client credentials (obtained from WISEflow admin / Service Centre)
WISEFLOW_CLIENT_ID=your_client_id
WISEFLOW_CLIENT_SECRET=your_client_secret

# ── Package 04 only ─────────────────────────────────────────────────────────
# Target SIS/LMS endpoint to receive grade passback (can be a local mock server)
SIS_ENDPOINT=http://localhost:8080/api/v1/grades
SIS_API_KEY=your_sis_api_key
